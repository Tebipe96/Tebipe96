#OPERADORES LOGICOS
print(6 > 3 and 6 > 10) # como la dos condiciones no se cumple el resultado es falso
print(6 > 3 and 6 < 10) # como las dos conciciones se cumple el resultado es verdadero
print(6 > 3 or 6 > 10) # como una de las condiciones se cumple el resultado es verdadero.
print(not (6 > 3)) # como la condiciones se cumple el resultado es falso, el operadore not invierte el resultado, por lo tanto el resultado es falso.

print("hola" < "mundo") # m es mayor que h, por lo tanto el resultado es verdadero